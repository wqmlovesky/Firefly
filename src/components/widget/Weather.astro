---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

const WEATHER_API = "https://api.bugpk.com/api/weather";
const CITY = "广州";
const FETCH_TIMEOUT = 5000;

interface WeatherData {
	cityInfo: {
		city: string;
		citykey: number;
		parent: string;
		updateTime: string;
	};
	data: {
		shidu: string;
		pm25: number;
		pm10: number;
		quality: string;
		wendu: number;
		ganmao: string;
		forecast: Array<{
			type: string;
			fx: string;
			fl: string;
			aqi: number;
			notice: string;
			high: string;
			low: string;
			sunrise: string;
			sunset: string;
			ymd: string;
			week: string;
		}>;
	};
	code: number;
	message: string;
	date: number;
	time: string;
}

let weatherData: WeatherData | null = null;
let error: string | null = null;

try {
	const controller = typeof AbortController !== 'undefined' ? new AbortController() : null;
	const timeoutId = setTimeout(() => {
		if (controller) controller.abort();
	}, FETCH_TIMEOUT);
	
	try {
		const response = await fetch(`${WEATHER_API}?city=${encodeURIComponent(CITY)}`, {
			signal: controller?.signal
		});
		
		clearTimeout(timeoutId);
		
		if (response.ok) {
			const data = await response.json();
			if (data.code === 200) {
				weatherData = data;
			} else {
				error = data.message || "获取失败";
			}
		} else {
			error = `HTTP ${response.status}`;
		}
	} catch (e) {
		clearTimeout(timeoutId);
		if (e.name === 'AbortError') {
			error = "请求超时";
		} else {
			error = e.message || "请求异常";
		}
	}
} catch (e) {
	error = e.message || "请求异常";
}
---

<WidgetLayout id="weather-widget" name={i18n(I18nKey.weather)} class={className} style={style}>
	<div class="weather-container">
		{error && (
			<div class="weather-error">
				<Icon name="fa7-solid:cloud-rain" class="error-icon" />
				<span>{i18n(I18nKey.weatherError)}</span>
			</div>
		)}
		{!error && !weatherData && (
			<div class="weather-loading">
				<Icon name="fa7-solid:spinner" class="loading-icon animate-spin" />
				<span>{i18n(I18nKey.weatherLoading)}</span>
			</div>
		)}
		{weatherData && (
			<div class="weather-content">
				<div class="weather-current">
					<div class="weather-header-row">
						<div class="weather-location">
							<Icon name="fa7-solid:location-dot" class="location-icon" />
                            <span class="weather-province">{weatherData.cityInfo?.parent || "--"}</span>
							<span>{weatherData.cityInfo?.city || CITY}</span>
						</div>
						<span class="weather-type-badge">{weatherData.data?.forecast?.[0]?.type || "--"}</span>
					</div>
					
					<div class="weather-main">
						<div class="weather-temperature">
							<span>{weatherData.data?.wendu !== undefined ? weatherData.data?.wendu : "--"}</span>
							<span class="temp-unit">°C</span>
						</div>
					</div>
                    
					<div class="weather-info">
						<div class="info-item">
							<Icon name="fa7-solid:droplet" class="info-icon" />
							<span>{i18n(I18nKey.weatherHumidity)}:</span>
							<span>{weatherData.data?.shidu || "--"}</span>
						</div>
						<div class="info-item">
							<Icon name="fa7-solid:wind" class="info-icon" />
							<span>{i18n(I18nKey.weatherWind)}:</span>
							<span>{`${weatherData.data?.forecast?.[0]?.fx || "--"} ${weatherData.data?.forecast?.[0]?.fl || ""}`.trim()}</span>
						</div>
						<div class="info-item">
							<Icon name="fa7-solid:leaf" class="info-icon" />
							<span>{i18n(I18nKey.weatherAqi)}:</span>
							<span>{weatherData.data?.forecast?.[0]?.aqi !== undefined ? weatherData.data?.forecast?.[0]?.aqi : "--"}</span>
							<span class={`quality-tag quality-${(function(aqi) { if(aqi === undefined) return "unknown"; if(aqi <= 50) return "good"; if(aqi <= 100) return "moderate"; if(aqi <= 150) return "light"; if(aqi <= 200) return "moderate-pollution"; if(aqi <= 300) return "heavy"; return "severe"; })(weatherData.data?.forecast?.[0]?.aqi)}`}>
								{(function(aqi) { if(aqi === undefined) return "未知"; if(aqi <= 50) return "优"; if(aqi <= 100) return "良"; if(aqi <= 150) return "轻度污染"; if(aqi <= 200) return "中度污染"; if(aqi <= 300) return "重度污染"; return "严重污染"; })(weatherData.data?.forecast?.[0]?.aqi)}
							</span>
						</div>
                        <div class="info-row">
							<div class="info-item">
								<Icon name="entypo:air" class="info-icon" />
								<span>PM2.5:</span>
								<span>{weatherData.data?.pm25 !== undefined ? weatherData.data?.pm25 : "--"}</span>
							</div>
							<div class="info-item">
								<Icon name="entypo:air" class="info-icon" />
								<span>PM10:</span>
								<span>{weatherData.data?.pm10 !== undefined ? weatherData.data?.pm10 : "--"}</span>
							</div>
						</div>
						<div class="info-row">
							<div class="info-item">
								<Icon name="iconoir:temperature-high" class="info-icon" />
								<span>{weatherData.data?.forecast?.[0]?.high || "--"}</span>
							</div>
							<div class="info-item">
								<Icon name="iconoir:temperature-low" class="info-icon" />
								<span>{weatherData.data?.forecast?.[0]?.low || "--"}</span>
							</div>
						</div>
						<div class="info-row">
							<div class="info-item"> 
								<Icon name="mi:sunrise-alt" class="info-icon" />
								<span>日出:</span>
								<span>{weatherData.data?.forecast?.[0]?.sunrise || "--"}</span>
							</div>
							<div class="info-item">
								<Icon name="tabler:sunset-2" class="info-icon" />
								<span>日落:</span>
								<span>{weatherData.data?.forecast?.[0]?.sunset || "--"}</span>
							</div>
						</div>
					</div>

					<div class="weather-sub-header">
						<span class="weather-date">{weatherData.data?.forecast?.[0]?.ymd || "--"}</span>
						<span class="weather-week">{weatherData.data?.forecast?.[0]?.week || "--"}</span>
					</div>
					<div class="weather-notice">
						<Icon name="fa7-solid:circle-info" class="notice-icon" />
						<span>{weatherData.data?.forecast?.[0]?.notice || ""}</span>
					</div>
					
                    {/* 更新时间 */}
					{/* <div class="weather-update">
						<Icon name="fa7-regular:clock" class="update-icon" />
						<span>{i18n(I18nKey.weatherUpdate)}:</span>
						<span>{weatherData.cityInfo?.updateTime || "--"}</span>
					</div> */}
				</div>
			</div>
		)}
	</div>
</WidgetLayout>

<style>
	.weather-container {
		display: flex;
		flex-direction: column;
	}

	.weather-loading,
	.weather-error {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem 1rem;
		gap: 0.5rem;
		color: var(--text-secondary);
	}

	.loading-icon,
	.error-icon {
		font-size: 2rem;
	}

	.weather-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.weather-current {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.weather-header-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.weather-location {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-primary);
	}

	.location-icon {
		font-size: 1.2rem;
		color: var(--primary-color);
	}

	.weather-type-badge {
		font-size: 1.1rem;
		color: var(--text-secondary);
		padding: 0.25rem 0.75rem;
		background: var(--bg-tertiary);
		border-radius: 9999px;
	}

	.weather-main {
		display: flex;
		align-items: flex-end;
        color: var(--primary);
	}

	.weather-temperature {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--text-primary);
		line-height: 1;
	}

	.temp-unit {
		font-size: 1.5rem;
		font-weight: 400;
		opacity: 0.8;
	}

	.weather-sub-header {
		display: flex;
		align-items: center;
        justify-content: space-around;
		gap: 1rem;
		font-size: 0.85rem;
		color: var(--text-tertiary);
	}

	.weather-province,
	.weather-date,
	.weather-week {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.weather-info {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		background: var(--bg-tertiary);
		border-radius: 0.75rem;
	}

	.info-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.87rem;
		color: var(--text-secondary);
	}

	.info-icon {
		font-size: 1rem;
		color: var(--primary-color);
		opacity: 0.8;
	}

	.info-row {
		display: flex;
		gap: 0.4rem;
	}

	.info-row .info-item {
		flex: 1;
	}

	.quality-tag {
		padding: 0.125rem 0.5rem;
		border-radius: 0.5rem;
		font-size: 0.75rem;
		font-weight: 500;
		margin-left: 0.25rem;
	}

	.quality-good {
		background: #e8f5e9;
		color: #2e7d32;
	}

	.quality-moderate {
		background: #fff3e0;
		color: #ef6c00;
	}

	.quality-light {
		background: #fff8e1;
		color: #f57c00;
	}

	.quality-moderate-pollution {
		background: #ffebee;
		color: #c62828;
	}

	.quality-heavy {
		background: #f3e5f5;
		color: #6a1b9a;
	}

	.quality-severe {
		background: #212121;
		color: #ffffff;
	}

	.quality-unknown {
		background: #eeeeee;
		color: #757575;
	}

	.ganmao-icon {
		font-size: 1rem;
		color: #4caf50;
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	.weather-notice {
		display: flex;
		align-items: flex-start;
        justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem;
		background: rgba(245, 158, 11, 0.1);
		border-radius: 0.75rem;
		font-size: 0.875rem;
		color: var(--text-secondary);
	}

	.notice-icon {
		font-size: 1rem;
		color: #ff9800;
		flex-shrink: 0;
		margin-top: 0.125rem;
	}

	.weather-update {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		color: var(--text-tertiary);
	}

	.update-icon {
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.weather-content {
			gap: 1rem;
		}

		.weather-current {
			gap: 0.75rem;
		}

		.weather-header-row {
			gap: 0.5rem;
		}

		.weather-location {
			font-size: 1.5rem;
		}

		.location-icon {
			font-size: 1.1rem;
		}

		.weather-type-badge {
			font-size: 1.5rem;
		}

		.weather-main {
			display: flex;
			align-items: flex-end;
            justify-content: center;
			gap: 0.5rem;
		}

		.weather-temperature {
			font-size: 2rem;
		}

		.temp-unit {
			font-size: 1.25rem;
		}

		.weather-info {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.75rem;
		}

		.info-item {
		flex: 1;
        min-width: calc(50% - 0.375rem);
        gap: 0.4rem;
        font-size: 1rem;
        justify-content: center;
		}

		.info-icon {
			font-size: 0.9rem;
		}

		.notice-icon {
			font-size: 0.9rem;
			margin-top: 0;
		}

		.weather-update {
			font-size: 0.7rem;
			gap: 0.375rem;
		}

		.update-icon {
			font-size: 0.8rem;
		}

		.weather-sub-header {
			gap: 0.5rem;
			font-size: 1rem;
			flex-wrap: wrap;
		}

		.ganmao-icon {
			font-size: 0.9rem;
			margin-top: 0;
		}
	}
</style>
